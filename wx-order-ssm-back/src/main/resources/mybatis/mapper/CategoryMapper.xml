<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.wechat.ordering.mapper.CategoryMapper">

    <resultMap id="CategoryResultMap" type="Category">
        <id column="id" property="id" />
        <result column="category-name" property="categoryName" />
        <result column="sort" property="sort" />
        <result column="create-time" property="createTime" />
    </resultMap>

    <select id="selectAll" resultMap="CategoryResultMap">
        SELECT id, `category-name`, sort, `create-time`
        FROM t_category ORDER BY sort ASC
    </select>

    <select id="selectById" parameterType="long" resultMap="CategoryResultMap">
        SELECT id, `category-name`, sort, `create-time`
        FROM t_category WHERE id = #{id}
    </select>

    <insert id="insert" parameterType="Category" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO t_category (`category-name`, sort, `create-time`)
        VALUES (#{categoryName}, #{sort}, #{createTime})
    </insert>

    <update id="update" parameterType="Category">
        UPDATE t_category SET
            `category-name` = #{categoryName},
            sort = #{sort}
        WHERE id = #{id}
    </update>

    <delete id="deleteById" parameterType="long">
        DELETE FROM t_category WHERE id = #{id}
    </delete>

</mapper>
